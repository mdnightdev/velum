# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Neon PostgreSQL database connection string for backup/persistence.
DATABASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DB_ENCRYPTION_KEY: The main symmetric database key (random Hex string).
DB_ENCRYPTION_KEY=""

# DB_ENCRYPTION_SALT: Optional database encryption salt.
DB_ENCRYPTION_SALT=""

# MIDNIGHT_PASSWORD: Custom login password for the Midnight admin account (CLI_ADMIN).
MIDNIGHT_PASSWORD=""

# MIDNIGHT_SAFE_WORD: Custom safeword for the Midnight admin account.
MIDNIGHT_SAFE_WORD=""

# MIDNIGHT_PANIC_PHRASE: Custom panic phrase for the Midnight admin account.
MIDNIGHT_PANIC_PHRASE=""

# MIDNIGHT_RECOVERY_KEY: Custom recovery key for the Midnight admin account.
MIDNIGHT_RECOVERY_KEY=""

# LEXIE_PASSWORD: Custom login password for the Lexie admin account (LOGIN_ADMIN).
LEXIE_PASSWORD=""

# LEXIE_SAFE_WORD: Custom safeword for the Lexie admin account.
LEXIE_SAFE_WORD=""

# LEXIE_PANIC_PHRASE: Custom panic phrase for the Lexie admin account.
LEXIE_PANIC_PHRASE=""

# LEXIE_RECOVERY_KEY: Custom recovery key for the Lexie admin account.
LEXIE_RECOVERY_KEY=""

# Cloudflare R2 / Amazon S3 Object Storage Configuration
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_PUBLIC_URL=""
